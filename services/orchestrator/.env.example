# Copy this file to .env to override defaults locally. .env is gitignored.

# Downstream service URLs — defaults match the ports used in this repo's
# .claude/launch.json for local dev.
ORCHESTRATOR_CV_PARSER_BASE_URL=http://localhost:8100
ORCHESTRATOR_INTERVIEW_QA_BASE_URL=http://localhost:8000
ORCHESTRATOR_SPEECH_IO_BASE_URL=http://localhost:8001
ORCHESTRATOR_ANSWER_GRADING_BASE_URL=http://localhost:8002
ORCHESTRATOR_CODE_EVAL_BASE_URL=http://localhost:8003
ORCHESTRATOR_BIOMETRIC_AUTH_BASE_URL=http://localhost:8005
ORCHESTRATOR_PROCTORING_BASE_URL=http://localhost:8006

# Only needed if the corresponding downstream service has its own
# REQUIRE_API_KEY turned on.
# ORCHESTRATOR_INTERVIEW_QA_API_KEY=
# ORCHESTRATOR_SPEECH_IO_API_KEY=
# ORCHESTRATOR_ANSWER_GRADING_API_KEY=
# ORCHESTRATOR_CODE_EVAL_API_KEY=
# ORCHESTRATOR_CV_PARSER_API_KEY=
# ORCHESTRATOR_BIOMETRIC_AUTH_API_KEY=
# ORCHESTRATOR_PROCTORING_API_KEY=

# When set, /api/v1/sessions requires candidate_id + face_files and
# rejects session creation on a biometric non-match. Off by default —
# opt in once biometric-auth has enrolled candidates to verify against.
# ORCHESTRATOR_REQUIRE_BIOMETRIC_VERIFICATION=1

ORCHESTRATOR_REDIS_URI=redis://localhost:6379

# ORCHESTRATOR_REQUIRE_API_KEY=1
# ORCHESTRATOR_API_KEYS=some-shared-secret
