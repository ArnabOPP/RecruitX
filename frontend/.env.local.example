# Copy to .env.local for local dev. Only read server-side (Next.js Route
# Handlers proxy to these) — never exposed to the browser, so no NEXT_PUBLIC_
# prefix. This avoids needing CORS configured on the backend services at all:
# the browser only ever talks to this Next.js server, which talks to the
# backend server-to-server.
ORCHESTRATOR_BASE_URL=http://localhost:8004
BIOMETRIC_AUTH_BASE_URL=http://localhost:8005

# Only needed if the corresponding backend service has REQUIRE_API_KEY set.
# ORCHESTRATOR_API_KEY=
# BIOMETRIC_AUTH_API_KEY=

# How often (ms) the interview page captures and submits a proctoring
# snapshot while a session is in_progress/awaiting_code.
NEXT_PUBLIC_PROCTORING_SNAPSHOT_INTERVAL_MS=8000
